# .env.example
# 复制此文件为 .env 并根据你的环境修改

# === 后端配置 ===
PORT=3000
NODE_ENV=development
DATABASE_URL=sqlite:./data/database.sqlite

# AI 服务地址
AI_SERVICE_URL=http://localhost:5000

# JWT 密钥（生产环境需要更强的密钥）
JWT_SECRET=change-me-in-production-use-strong-secret-key

# 文件限制
MAX_FILE_SIZE=209715200

# 上传目录
UPLOAD_DIR=./uploads

# 日志级别
LOG_LEVEL=debug

# === 前端配置 ===
VITE_API_URL=http://localhost:3000
VITE_AI_URL=http://localhost:5000

# === 数据库配置 ===
# SQLite（开发）
# DATABASE_URL=sqlite:./data/database.sqlite

# PostgreSQL（生产）
# DATABASE_URL=postgresql://user:password@localhost:5432/video_audit

# === AI 服务配置 ===
FLASK_ENV=development
PYTHONUNBUFFERED=1

# === 邮件配置（可选）===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM=noreply@video-audit.com
